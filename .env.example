# Copy this file to .env and fill in real values. Do not commit .env.

# Generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=replace-with-a-generated-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_TIME_ZONE=UTC

# PostgreSQL connection
DATABASE_NAME=fitlogger
DATABASE_USER=postgres
DATABASE_PASSWORD=your-postgres-password
DATABASE_HOST=localhost
DATABASE_PORT=5432

# AI planner (server-side only — never exposed to the browser)
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-key-here
OPENAI_MODEL=gpt-4o-mini
AI_REQUEST_TIMEOUT_SECONDS=60

# Admin account password (used only by: python manage.py seed_admin)
ADMIN_PASSWORD=set-a-strong-admin-password
